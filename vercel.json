{
  "version": 2,
  "builds": [
    {
      "src": "src/api/**/*.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/auth/(.*)",
      "dest": "/src/api/auth/$1.ts"
    }
  ],
  "env": {
    "GITHUB_CLIENT_ID": "@GITHUB_CLIENT_ID",
    "GITHUB_CLIENT_SECRET": "@GITHUB_CLIENT_SECRET"
  }
}
